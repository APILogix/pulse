{
  "name": "pulsiv",
  "version": "2.6.9",
  "description": "See [docs/enterprise-auth-implementation-plan.md](docs/enterprise-auth-implementation-plan.md) for the enterprise-grade backend remediation plan.",
  "main": "index.js",
  "directories": {
    "doc": "docs",
    "test": "test"
  },
  "scripts": {
    "dev": "tsx watch src/main.ts",
    "dev:workers": "tsx watch src/shared/workers/main.ts",
    "dev:ingestion": "tsx watch src/shared/workers/ingestion-worker-main.ts",
    "dev:cron": "tsx watch src/shared/workers/cron.ts",
    "build": "tsc",
    "start": "node dist/main.js",
    "start:prod": "NODE_ENV=production node --max-old-space-size=512 dist/main.js",
    "start:workers": "node dist/shared/workers/main.js",
    "start:ingestion": "node dist/shared/workers/ingestion-worker-main.js",
    "start:cron": "node dist/shared/workers/cron.js",
    "pm2:start": "npx pm2 start ecosystem.config.cjs --env production",
    "pm2:stop": "npx pm2 stop api-backend",
    "pm2:restart": "npx pm2 restart api-backend",
    "pm2:reload": "npx pm2 reload api-backend",
    "pm2:delete": "npx pm2 delete api-backend",
    "pm2:logs": "npx pm2 logs api-backend",
    "pm2:monit": "npx pm2 monit",
    "pm2:status": "npx pm2 list",
    "lint": "eslint src --ext .ts",
    "test": "vitest",
    "test:integration": "vitest --config vitest.integration.config.ts",
    "db:migrate": "tsx scripts/setup-db.ts",
    "db:migrate:draft": "tsx scripts/setup-db.ts --migrations-profile draft",
    "db:seed": "tsx scripts/seed.ts",
    "db:indexes": "tsx scripts/add-indexes.ts"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "module",
  "dependencies": {
    "@clickhouse/client": "^1.18.2",
    "@fastify/compress": "^8.3.1",
    "@fastify/cookie": "^11.0.2",
    "@fastify/cors": "^11.2.0",
    "@fastify/helmet": "^13.0.2",
    "@fastify/passport": "^3.0.2",
    "@fastify/rate-limit": "^10.3.0",
    "@fastify/secure-session": "^8.3.0",
    "@fastify/sensible": "^6.0.4",
    "@fastify/swagger": "^9.7.0",
    "@fastify/swagger-ui": "^5.2.5",
    "@fastify/under-pressure": "^9.0.3",
    "@node-saml/node-saml": "^5.1.0",
    "@simplewebauthn/server": "^13.3.1",
    "bcrypt": "^6.0.0",
    "bullmq": "^5.73.0",
    "dotenv": "^17.4.0",
    "fastify": "^5.8.4",
    "fastify-plugin": "^5.1.0",
    "fastify-raw-body": "^5.0.0",
    "fastify-type-provider-zod": "^6.1.0",
    "ioredis": "^5.10.1",
    "jsonwebtoken": "^9.0.3",
    "lru-cache": "^11.3.5",
    "nanoid": "^5.1.7",
    "nodemailer": "^8.0.7",
    "openai": "^6.33.0",
    "openid-client": "^6.8.4",
    "opossum": "^9.0.0",
    "otpauth": "^9.5.0",
    "p-limit": "^7.3.0",
    "p-map": "^7.0.5",
    "passport": "^0.7.0",
    "passport-github2": "^0.1.12",
    "passport-google-oauth20": "^2.0.0",
    "pg": "^8.20.0",
    "pg-boss": "^12.22.0",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "prom-client": "^15.1.3",
    "qrcode": "^1.5.4",
    "svix": "^1.90.0",
    "ts-morph": "^28.0.0",
    "uuid": "^13.0.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@testcontainers/clickhouse": "^11.13.0",
    "@testcontainers/postgresql": "^11.13.0",
    "@types/bcrypt": "^6.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^25.5.2",
    "@types/nodemailer": "^8.0.0",
    "@types/passport": "^1.0.17",
    "@types/passport-github2": "^1.2.9",
    "@types/passport-google-oauth20": "^2.0.17",
    "@types/pg": "^8.20.0",
    "@types/pino": "^7.0.4",
    "@types/qrcode": "^1.5.6",
    "@types/uuid": "^10.0.0",
    "nodemon": "^3.1.14",
    "pm2": "^7.0.1",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "vitest": "^4.1.2"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/APILogix/pulse.git"
  },
  "bugs": {
    "url": "https://github.com/APILogix/pulse/issues"
  },
  "homepage": "https://github.com/APILogix/pulse#readme"
}
