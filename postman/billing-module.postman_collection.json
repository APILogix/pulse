{
  "info": {
    "name": "API Monitoring Backend - Billing Module",
    "_postman_id": "4d5b43fb-22dd-4624-b2d8-bf5f87eecf8f",
    "description": "Postman collection for /billing routes.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{token}}",
        "type": "string"
      }
    ]
  },
  "event": [],
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:3000" },
    { "key": "token", "value": "" },
    { "key": "orgId", "value": "" },
    { "key": "planId", "value": "starter" },
    { "key": "newPlanId", "value": "professional" },
    { "key": "paymentMethodId", "value": "" },
    { "key": "invoiceId", "value": "" },
    { "key": "quotaType", "value": "api_requests" },
    { "key": "provider", "value": "stripe" }
  ],
  "item": [
    {
      "name": "Plans",
      "item": [
        {
          "name": "List Plans",
          "request": {
            "method": "GET",
            "header": [{ "key": "x-org-id", "value": "{{orgId}}" }],
            "url": "{{baseUrl}}/billing/plans"
          }
        },
        {
          "name": "Get Plan",
          "request": {
            "method": "GET",
            "header": [{ "key": "x-org-id", "value": "{{orgId}}" }],
            "url": "{{baseUrl}}/billing/plans/{{planId}}"
          }
        },
        {
          "name": "Compare Plans",
          "request": {
            "method": "GET",
            "header": [{ "key": "x-org-id", "value": "{{orgId}}" }],
            "url": "{{baseUrl}}/billing/plans/compare"
          }
        },
        {
          "name": "Estimate Plan Pricing",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "x-org-id", "value": "{{orgId}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"planId\": \"{{planId}}\",\n  \"interval\": \"monthly\",\n  \"couponCode\": \"WELCOME10\"\n}"
            },
            "url": "{{baseUrl}}/billing/plans/estimate"
          }
        }
      ]
    },
    {
      "name": "Subscription",
      "item": [
        {
          "name": "Get Subscription",
          "request": {
            "method": "GET",
            "header": [{ "key": "x-org-id", "value": "{{orgId}}" }],
            "url": "{{baseUrl}}/billing/subscription"
          }
        },
        {
          "name": "Create Subscription",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "x-org-id", "value": "{{orgId}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"planId\": \"{{planId}}\",\n  \"billingInterval\": \"monthly\",\n  \"paymentMethodId\": \"{{paymentMethodId}}\"\n}"
            },
            "url": "{{baseUrl}}/billing/subscription"
          }
        },
        {
          "name": "Change Subscription Plan",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "x-org-id", "value": "{{orgId}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"planId\": \"{{newPlanId}}\",\n  \"prorationBehavior\": \"create_prorations\"\n}"
            },
            "url": "{{baseUrl}}/billing/subscription/plan"
          }
        },
        {
          "name": "Preview Plan Change",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "x-org-id", "value": "{{orgId}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"newPlanId\": \"{{newPlanId}}\"\n}"
            },
            "url": "{{baseUrl}}/billing/subscription/preview-change"
          }
        },
        {
          "name": "Cancel Subscription",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "x-org-id", "value": "{{orgId}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"reason\": \"No longer needed\",\n  \"immediate\": false\n}"
            },
            "url": "{{baseUrl}}/billing/subscription/cancel"
          }
        },
        {
          "name": "Reactivate Subscription",
          "request": {
            "method": "POST",
            "header": [{ "key": "x-org-id", "value": "{{orgId}}" }],
            "url": "{{baseUrl}}/billing/subscription/reactivate"
          }
        }
      ]
    },
    {
      "name": "Payment Methods",
      "item": [
        {
          "name": "List Payment Methods",
          "request": {
            "method": "GET",
            "header": [{ "key": "x-org-id", "value": "{{orgId}}" }],
            "url": "{{baseUrl}}/billing/payment-methods"
          }
        },
        {
          "name": "Add Payment Method",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "x-org-id", "value": "{{orgId}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"type\": \"card\",\n  \"stripePaymentMethodId\": \"pm_test_123\",\n  \"billingDetails\": {\n    \"name\": \"Billing User\",\n    \"email\": \"billing@example.com\"\n  }\n}"
            },
            "url": "{{baseUrl}}/billing/payment-methods"
          }
        },
        {
          "name": "Set Default Payment Method",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "x-org-id", "value": "{{orgId}}" }],
            "url": "{{baseUrl}}/billing/payment-methods/{{paymentMethodId}}/default"
          }
        },
        {
          "name": "Update Payment Method",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "x-org-id", "value": "{{orgId}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"billingDetails\": {\n    \"name\": \"Updated Billing Name\"\n  }\n}"
            },
            "url": "{{baseUrl}}/billing/payment-methods/{{paymentMethodId}}"
          }
        },
        {
          "name": "Verify Payment Method",
          "request": {
            "method": "POST",
            "header": [{ "key": "x-org-id", "value": "{{orgId}}" }],
            "url": "{{baseUrl}}/billing/payment-methods/{{paymentMethodId}}/verify"
          }
        },
        {
          "name": "Delete Payment Method",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "x-org-id", "value": "{{orgId}}" }],
            "url": "{{baseUrl}}/billing/payment-methods/{{paymentMethodId}}"
          }
        }
      ]
    },
    {
      "name": "Invoices",
      "item": [
        {
          "name": "List Invoices",
          "request": {
            "method": "GET",
            "header": [{ "key": "x-org-id", "value": "{{orgId}}" }],
            "url": "{{baseUrl}}/billing/invoices?status=paid&page=1&limit=10"
          }
        },
        {
          "name": "Get Invoice",
          "request": {
            "method": "GET",
            "header": [{ "key": "x-org-id", "value": "{{orgId}}" }],
            "url": "{{baseUrl}}/billing/invoices/{{invoiceId}}"
          }
        },
        {
          "name": "Download Invoice PDF",
          "request": {
            "method": "GET",
            "header": [{ "key": "x-org-id", "value": "{{orgId}}" }],
            "url": "{{baseUrl}}/billing/invoices/{{invoiceId}}/pdf"
          }
        },
        {
          "name": "Pay Invoice",
          "request": {
            "method": "POST",
            "header": [{ "key": "x-org-id", "value": "{{orgId}}" }],
            "url": "{{baseUrl}}/billing/invoices/{{invoiceId}}/pay"
          }
        },
        {
          "name": "Upcoming Invoice",
          "request": {
            "method": "GET",
            "header": [{ "key": "x-org-id", "value": "{{orgId}}" }],
            "url": "{{baseUrl}}/billing/invoices/upcoming"
          }
        }
      ]
    },
    {
      "name": "Usage and Quotas",
      "item": [
        {
          "name": "Current Usage",
          "request": {
            "method": "GET",
            "header": [{ "key": "x-org-id", "value": "{{orgId}}" }],
            "url": "{{baseUrl}}/billing/usage"
          }
        },
        {
          "name": "Detailed Usage",
          "request": {
            "method": "GET",
            "header": [{ "key": "x-org-id", "value": "{{orgId}}" }],
            "url": "{{baseUrl}}/billing/usage/detailed?granularity=daily"
          }
        },
        {
          "name": "Usage History",
          "request": {
            "method": "GET",
            "header": [{ "key": "x-org-id", "value": "{{orgId}}" }],
            "url": "{{baseUrl}}/billing/usage/history?type=api_requests"
          }
        },
        {
          "name": "Usage Forecast",
          "request": {
            "method": "GET",
            "header": [{ "key": "x-org-id", "value": "{{orgId}}" }],
            "url": "{{baseUrl}}/billing/usage/forecast"
          }
        },
        {
          "name": "Export Usage",
          "request": {
            "method": "GET",
            "header": [{ "key": "x-org-id", "value": "{{orgId}}" }],
            "url": "{{baseUrl}}/billing/usage/export?format=csv"
          }
        },
        {
          "name": "Quota Status",
          "request": {
            "method": "GET",
            "header": [{ "key": "x-org-id", "value": "{{orgId}}" }],
            "url": "{{baseUrl}}/billing/quotas"
          }
        },
        {
          "name": "Quota Details",
          "request": {
            "method": "GET",
            "header": [{ "key": "x-org-id", "value": "{{orgId}}" }],
            "url": "{{baseUrl}}/billing/quotas/{{quotaType}}"
          }
        },
        {
          "name": "Request Quota Increase",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "x-org-id", "value": "{{orgId}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"requestedLimit\": 200000,\n  \"reason\": \"Expected traffic increase\"\n}"
            },
            "url": "{{baseUrl}}/billing/quotas/{{quotaType}}/increase"
          }
        },
        {
          "name": "List Quota Requests",
          "request": {
            "method": "GET",
            "header": [{ "key": "x-org-id", "value": "{{orgId}}" }],
            "url": "{{baseUrl}}/billing/quotas/requests"
          }
        }
      ]
    },
    {
      "name": "Billing Settings",
      "item": [
        {
          "name": "Get Billing Settings",
          "request": {
            "method": "GET",
            "header": [{ "key": "x-org-id", "value": "{{orgId}}" }],
            "url": "{{baseUrl}}/billing/settings"
          }
        },
        {
          "name": "Update Billing Settings",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "x-org-id", "value": "{{orgId}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"netTermsDays\": 30\n}"
            },
            "url": "{{baseUrl}}/billing/settings"
          }
        },
        {
          "name": "Update Billing Email",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "x-org-id", "value": "{{orgId}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"billing@example.com\"\n}"
            },
            "url": "{{baseUrl}}/billing/settings/email"
          }
        },
        {
          "name": "Update Billing Address",
          "request": {
            "method": "PATCH",
