            "body": {
              "mode": "raw",
              "raw": "{\n  \"address\": {\n    \"street\": \"123 Main St\",\n    \"city\": \"Bengaluru\",\n    \"state\": \"KA\",\n    \"zip\": \"560001\",\n    \"country\": \"IN\"\n  }\n}"
            },
            "url": "{{baseUrl}}/billing/settings/address"
          }
        },
        {
          "name": "Update Tax Settings",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "x-org-id", "value": "{{orgId}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"taxId\": \"29ABCDE1234F2Z5\"\n}"
            },
            "url": "{{baseUrl}}/billing/settings/tax"
          }
        }
      ]
    },
    {
      "name": "Coupons and Promotions",
      "item": [
        {
          "name": "Apply Coupon",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "x-org-id", "value": "{{orgId}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"code\": \"WELCOME10\"\n}"
            },
            "url": "{{baseUrl}}/billing/coupons/apply"
          }
        },
        {
          "name": "Remove Coupon",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "x-org-id", "value": "{{orgId}}" }],
            "url": "{{baseUrl}}/billing/coupons"
          }
        },
        {
          "name": "Validate Coupon",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "x-org-id", "value": "{{orgId}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"code\": \"WELCOME10\"\n}"
            },
            "url": "{{baseUrl}}/billing/coupons/validate"
