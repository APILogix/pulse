        {
          "name": "List Promotions",
          "request": {
            "method": "GET",
            "header": [{ "key": "x-org-id", "value": "{{orgId}}" }],
            "url": "{{baseUrl}}/billing/promotions"
          }
        }
      ]
    },
    {
      "name": "Webhooks",
      "item": [
        {
          "name": "Stripe Webhook",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "stripe-signature", "value": "t=123,v1=testsig" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"id\": \"evt_test_123\",\n  \"type\": \"invoice.paid\",\n  \"data\": {\n    \"object\": {}\n  }\n}"
            },
            "url": "{{baseUrl}}/billing/webhooks/stripe"
          }
        },
        {
          "name": "Generic Payment Webhook",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"type\": \"payment.success\",\n  \"data\": {}\n}"
            },
            "url": "{{baseUrl}}/billing/webhooks/{{provider}}"
          }
        }
      ]
    },
    {
      "name": "Admin",
      "item": [
        {
          "name": "Force Sync Billing",
          "request": {
            "method": "POST",
            "header": [{ "key": "x-org-id", "value": "{{orgId}}" }],
            "url": "{{baseUrl}}/billing/admin/sync"
          }
        },
        {
          "name": "Override Subscription",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "x-org-id", "value": "{{orgId}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"active\"\n}"
            },
            "url": "{{baseUrl}}/billing/admin/override"
          }
        },
        {
          "name": "Grant Credits",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "x-org-id", "value": "{{orgId}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"amount\": 100,\n  \"reason\": \"Support adjustment\"\n}"
            },
            "url": "{{baseUrl}}/billing/admin/credits"
          }
        },
        {
          "name": "Waive Invoice",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "x-org-id", "value": "{{orgId}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"reason\": \"Courtesy waiver\"\n}"
            },
            "url": "{{baseUrl}}/billing/admin/invoices/{{invoiceId}}/waive"
          }
        },
        {
          "name": "Billing Analytics",
          "request": {
            "method": "GET",
            "header": [{ "key": "x-org-id", "value": "{{orgId}}" }],
            "url": "{{baseUrl}}/billing/admin/analytics"
          }
        }
      ]
    },
    {
      "name": "Portal and Checkout",
      "item": [
        {
          "name": "Create Portal Session",
          "request": {
            "method": "POST",
            "header": [{ "key": "x-org-id", "value": "{{orgId}}" }],
            "url": "{{baseUrl}}/billing/portal/session"
          }
        },
