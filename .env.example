# ── Server ──────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
HOST=0.0.0.0
APP_NAME="API Monitoring"
APP_URL=http://localhost:3000

# ── Databases ───────────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/api_monitoring

# Log Database (optional, for separate analytics DB)
# LOG_DB_PRIMARY=
# LOG_DB_REPLICA=
# LOG_POOL_MAX=20
# LOG_POOL_MIN=5
# LOG_QUERY_TIMEOUT=30000
# LOG_RETRIES=3

# ClickHouse (optional)
# CLICKHOUSE_URL=

# ── Redis ───────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── Security ────────────────────────────────────────────────────────────
# Generate each value independently with: openssl rand -hex 32
# IMPORTANT: JWT_SECRET, JWT_REFRESH_SECRET, COOKIE_SECRET, and ENCRYPTION_KEY
# MUST be distinct. The application refuses to start if any two are equal.
JWT_SECRET=change-me-in-production-use-openssl-rand-hex-32
JWT_REFRESH_SECRET=change-me-in-production-use-openssl-rand-hex-32
COOKIE_SECRET=change-me-in-production-use-openssl-rand-hex-32
ENCRYPTION_KEY=change-me-32-characters-exactly!!

# CORS: comma-separated allowed origins (production only)
ALLOWED_ORIGINS=http://localhost:5173
FRONTEND_URL=http://localhost:5173

# ── Email / SMTP ────────────────────────────────────────────────────────
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM_EMAIL=noreply@example.com
# SMTP_FROM_NAME=API Monitoring

# ── AI (optional) ───────────────────────────────────────────────────────
# OPENAI_API_KEY=
