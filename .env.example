# ── Server ──────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=3000
HOST=0.0.0.0
APP_NAME="API Monitoring"
APP_URL=http://localhost:3000
API_PUBLIC_URL=http://localhost:3000

# ── Databases ───────────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/api_monitoring

# Log Database (optional, for separate analytics DB)
# LOG_DB_PRIMARY=
# LOG_DB_REPLICA=
# LOG_POOL_MAX=20
# LOG_POOL_MIN=5
# LOG_QUERY_TIMEOUT=30000
# LOG_RETRIES=3
# LOG_DB_SSL_ENABLED=false
# LOG_DB_SSL_REJECT_UNAUTHORIZED=true

# ClickHouse (optional)
# CLICKHOUSE_URL=

# ── Redis ───────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── Security ────────────────────────────────────────────────────────────
# Generate each value independently with: openssl rand -hex 32
# IMPORTANT: JWT_SECRET, JWT_REFRESH_SECRET, COOKIE_SECRET, and ENCRYPTION_KEY
# MUST be distinct. The application refuses to start if any two are equal.
JWT_SECRET=change-me-in-production-use-openssl-rand-hex-32
JWT_REFRESH_SECRET=change-me-in-production-use-openssl-rand-hex-32
COOKIE_SECRET=change-me-in-production-use-openssl-rand-hex-32
ENCRYPTION_KEY=change-me-32-characters-exactly!!

# CORS: comma-separated allowed origins (production only)
ALLOWED_ORIGINS=http://localhost:5173
FRONTEND_URL=http://localhost:5173

# Shared auth callback endpoints. Register these exact API URLs in provider consoles.
OIDC_CALLBACK_URL=http://localhost:3000/auth/sso/callback
SOCIAL_LOGIN_CALLBACK_URL=http://localhost:3000/auth/login/social/callback
IDENTITY_LINK_CALLBACK_URL=http://localhost:3000/auth/identity-providers/callback

# ── Email / SMTP ────────────────────────────────────────────────────────
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM_EMAIL=noreply@example.com
# SMTP_FROM_NAME=API Monitoring

# Social OAuth / identity linking (optional)
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=
# MICROSOFT_CLIENT_ID=
# MICROSOFT_CLIENT_SECRET=
# MICROSOFT_TENANT_ID=common

# Provider-console references:
# Google social login callback:     http://localhost:3000/auth/login/social/callback
# Google identity link callback:    http://localhost:3000/auth/identity-providers/callback
# GitHub social login callback:     http://localhost:3000/auth/login/social/callback
# GitHub identity link callback:    http://localhost:3000/auth/identity-providers/callback
# Microsoft social login callback:  http://localhost:3000/auth/login/social/callback
# Microsoft identity link callback: http://localhost:3000/auth/identity-providers/callback

# SAML Service Provider (optional)
# SAML_SP_ENTITY_ID=http://localhost:3000/auth/saml/metadata
# SAML_SP_ACS_URL=http://localhost:3000/auth/saml/acs
# SAML_SP_SLO_URL=http://localhost:3000/auth/saml/slo
# SAML_SP_PRIVATE_KEY=
# SAML_SP_CERTIFICATE=

# WebAuthn (optional)
# WEBAUTHN_RP_ID=localhost
# WEBAUTHN_RP_NAME=API Monitoring

# ── AI (optional) ───────────────────────────────────────────────────────
# OPENAI_API_KEY=

# == Ingestion pipeline (API path tunables) ==================================
# All optional; safe defaults applied in src/config/env.ts.
# INGESTION_MAX_BATCH_SIZE=1000
# INGESTION_DEFAULT_RATE_PER_SECOND=1000
# INGESTION_DEFAULT_RATE_PER_MINUTE=10000
# INGESTION_BACKPRESSURE_HIGH_WATER=100000
# INGESTION_BACKPRESSURE_CRITICAL_WATER=250000
# INGESTION_REPLAY_MAX_EVENTS=10000
# INGESTION_RATE_BUCKET_TTL_MS=300000
# INGESTION_RATE_BUCKET_SWEEP_MS=60000
# INGESTION_ENDPOINT=https://api.pulse.io/api/v1/ingest

# == Ingestion worker tier (v2) =============================================
# General lane (fast signals): error/message/request/span/metric/log/cron_checkin
# INGESTION_GENERAL_WORKERS=4
# INGESTION_GENERAL_CONCURRENCY=8
# INGESTION_GENERAL_BATCH_SIZE=50
# Specialized lane (heavy signals): profile/replay/trace
# INGESTION_SPECIALIZED_WORKERS=2
# INGESTION_SPECIALIZED_CONCURRENCY=4
# INGESTION_SPECIALIZED_BATCH_SIZE=10
# INGESTION_VISIBILITY_TIMEOUT_MS=300000
# INGESTION_SPECIALIZED_VISIBILITY_TIMEOUT_MS=600000
# INGESTION_POLL_MS=25
# INGESTION_IDLE_POLL_MS=500
# INGESTION_DB_POOL_SIZE=20
# INGESTION_RETRY_INTERVAL_MS=15000
# INGESTION_MAINTENANCE_INTERVAL_MS=21600000
# INGESTION_COMPLETED_RETENTION_MS=3600000

# == Usage counter (three-tier) =============================================
# INGESTION_USAGE_FLUSH_MS=30000
# INGESTION_USAGE_BUFFER_LIMIT=10000

# == TimescaleDB logging database (operational metrics + audit) =============
# Separate instance from DATABASE_URL. When unset, logging degrades to no-ops
# and admin logs still land in the primary DB (ingestion_admin_logs).
# TIMESCALEDB_URL=postgresql://user:pass@localhost:5433/pulse_logs
# INGESTION_LOG_DB_POOL_SIZE=5
# INGESTION_ADMIN_LOG_BUFFER_SIZE=100
# INGESTION_ADMIN_LOG_FLUSH_MS=5000
